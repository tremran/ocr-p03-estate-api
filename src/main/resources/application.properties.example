server.port=3001

spring.application.name=p03_estate_api

logging.level.org.springframework.web=DEBUG
logging.level.com.tremran.p03_estate_api.debugging=ERROR


spring.datasource.url=jdbc:mysql://localhost:3306/p03_estate?serverTimezone=UTC
spring.datasource.username=estate
spring.datasource.password=estate
spring.jpa.properties.hibernate.dialect = org.hibernate.dialect.MySQLDialect
spring.jpa.hibernate.naming.physical-strategy=org.hibernate.boot.model.naming.PhysicalNamingStrategyStandardImpl

security.jwt.secret-key=
security.jwt.expiration-time=